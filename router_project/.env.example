GROQ_API_KEY=your_groq_api_key_here
# Optional write protection for POST/PUT endpoints.
PROMPT_STUDIO_WRITE_API_KEY=
# Optional per-IP limit for API requests per minute. Set 0 to disable.
PROMPT_STUDIO_RATE_LIMIT_PER_MINUTE=120
# Optional frontend override if serving frontend from different domain.
# PROMPT_STUDIO_API_BASE=https://your-api-domain.example.com
